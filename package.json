{
  "name": "chatbot-juridique-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node ./scripts/dev-clean.mjs",
    "dev": "node ./scripts/ensure-port-free.mjs 3001 && next dev -p 3001",
    "dev:fast": "node ./scripts/ensure-port-free.mjs 3001 && next dev -p 3001",
    "dev:fresh": "node ./scripts/ensure-port-free.mjs 3001 && npm run clean && next dev -p 3001",
    "build": "next build",
    "vercel-build": "next build",
    "build:fresh": "npm run clean && next build",
    "start": "npm run build && next start -p 3001",
    "start:fast": "next start -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.0",
    "jspdf": "^4.2.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.3"
  }
}
