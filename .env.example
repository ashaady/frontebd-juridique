APP_ENV=development
LLM_PROVIDER=nvidia
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_API_KEY=ollama
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
NVIDIA_API_KEY=your_new_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-v3.2
NVIDIA_EMBEDDING_MODEL=
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:7410,http://127.0.0.1:7410
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|192\.168\.\d{1,3}\.\d{1,3}|172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3})(:\d+)?$
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
API_DOCS_ENABLED=true
REQUEST_MAX_BODY_MB=25
GZIP_ENABLED=true
GZIP_MIN_SIZE=500
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RAG_ENABLED=true
RAG_INDEX_DIR=data/index
LEGAL_DATA_DIR=droit donnees
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=12000
RAG_EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-l-v2.0
RAG_EMBEDDING_DEVICE=cuda
RAG_RERANKER_ENABLED=false
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANKER_DEVICE=
RAG_RERANKER_BATCH_SIZE=16
RAG_RERANKER_POOL_SIZE=50
RAG_DOMAIN_FILTER_ENABLED=true
RAG_TARGET_MIN_CHUNKS=8
RAG_TARGET_MAX_CHUNKS=10
RAG_ADAPTIVE_THRESHOLD_ENABLED=true
RAG_ADAPTIVE_THRESHOLD_FLOOR=0.22
RAG_ADAPTIVE_THRESHOLD_STEP=0.03
RAG_MIN_SOURCE_CITATIONS=3
RAG_NEUTRAL_FALLBACK_MAX=2
RAG_MIN_SCORE_THRESHOLD=0.35
RAG_MIN_CHUNKS_REQUIRED=2
RAG_RELEVANCE_CHECK_ENABLED=true
RAG_QUERY_REWRITE_ENABLED=true
RAG_QUERY_REWRITE_MODEL=
RAG_QUERY_REWRITE_MAX_TOKENS=96
RAG_QUERY_REWRITE_TEMPERATURE=0.0
SPEECH_ENABLED=true
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=fr
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true
